# ===========================================
# CONFIGURAÇÃO DE STAGING - GOOGLE ADS INTEGRATION
# ===========================================

# -----------------------------------------
# SUPABASE (Staging)
# -----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_staging_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_staging_supabase_service_role_key

# -----------------------------------------
# GOOGLE ADS API (Staging/Test)
# -----------------------------------------
# Use as mesmas credenciais de desenvolvimento para staging
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_DEVELOPER_TOKEN=your_google_developer_token
GOOGLE_TOKEN_ENCRYPTION_KEY=your_secure_random_encryption_key

# -----------------------------------------
# META ADS API (Staging/Test)
# -----------------------------------------
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# -----------------------------------------
# APLICAÇÃO (Staging)
# -----------------------------------------
# URL do ambiente de staging
NEXT_PUBLIC_APP_URL=https://your-app-staging.vercel.app

# -----------------------------------------
# AMBIENTE
# -----------------------------------------
NODE_ENV=staging

# -----------------------------------------
# CONFIGURAÇÕES DE TESTE
# -----------------------------------------
# Habilitar logs detalhados em staging
DEBUG=google-ads:*,meta-ads:*
LOG_LEVEL=debug

# Configurações específicas para staging
ENABLE_DEBUG_ENDPOINTS=true
SKIP_RATE_LIMITING=true
MOCK_EXTERNAL_APIS=false