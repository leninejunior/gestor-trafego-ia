{
  "crons": [
    {
      "path": "/api/cron/subscription-intent-expiration?type=warning",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/subscription-intent-expiration?type=expire",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/subscription-intent-expiration?type=cleanup",
      "schedule": "0 2 * * 0"
    }
  ]
}