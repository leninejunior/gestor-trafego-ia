{
  "mcpServers": {
    "stripe": {
      "url": "https://mcp.stripe.com",
      "disabled": true
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": true,
      "autoApprove": [
        "fetch"
      ],
      "disabledTools": []
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "disabled": false,
      "autoApprove": [
        "navigate_page",
        "list_pages",
        "take_snapshot",
        "click",
        "list_console_messages",
        "list_network_requests",
        "get_network_request",
        "new_page",
        "handle_dialog",
        "take_screenshot",
        "wait_for",
        "fill",
        "get_console_message",
        "press_key",
        "evaluate_script",
        "evaluate_script"
      ]
    },
    "supabase": {
      "url": "https://mcp.supabase.com/mcp?project_ref=doiogabdzybqxnyhktbv",
      "disabled": true
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:/vibecoding/projetos/flying-fox-bob"
      ],
      "disabled": false,
      "autoApprove": [
        "read_file",
        "list_directory",
        "search_files"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "C:/vibecoding/projetos/flying-fox-bob"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": true,
      "autoApprove": [
        "git_status",
        "git_diff",
        "git_log",
        "git_show"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "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"
      },
      "disabled": true,
      "autoApprove": []
    }
  }
}