# ===========================================
# CONFIGURAÇÃO DE PRODUÇÃO - ADS MANAGER
# ===========================================
# Este arquivo serve como template para configuração
# na sua plataforma de deploy. Copie estas variáveis para:
# Dashboard > Settings > Environment Variables
# ===========================================

# -----------------------------------------
# SUPABASE (Obrigatório)
# -----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_producao
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_producao

# -----------------------------------------
# API V1 (Fallback quando api_keys nao existir)
# -----------------------------------------
API_V1_FALLBACK_KEY=sk_your_fallback_key
API_V1_FALLBACK_ORGANIZATION_ID=your_org_uuid
API_V1_FALLBACK_PERMISSIONS=balance:read,campaigns:read,campaigns:write
# API_V1_KEYS_JSON=[{"key":"sk_key_1","organizationId":"org_uuid_1","permissions":["*"]}]

# -----------------------------------------
# META ADS API (Obrigatório)
# -----------------------------------------
META_APP_ID=seu_meta_app_id_producao
META_APP_SECRET=seu_meta_app_secret_producao

# -----------------------------------------
# APLICAÇÃO (Obrigatório)
# -----------------------------------------
# Atualize após primeiro deploy com a URL real
NEXT_PUBLIC_APP_URL=https://seu-dominio.com

# Secret para proteger endpoints /api/cron/*
CRON_SECRET=your_secure_cron_secret

# -----------------------------------------
# GOOGLE ADS API (Para Integração Google Ads)
# -----------------------------------------
GOOGLE_CLIENT_ID=seu_google_client_id_producao
GOOGLE_CLIENT_SECRET=seu_google_client_secret_producao
GOOGLE_DEVELOPER_TOKEN=seu_google_developer_token_producao

# -----------------------------------------
# STRIPE (Sistema de Assinaturas)
# -----------------------------------------
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# -----------------------------------------
# IUGU (Gateway de Pagamento)
# -----------------------------------------
# IUGU_API_TOKEN=
# IUGU_ACCOUNT_ID=
# NEXT_PUBLIC_IUGU_ACCOUNT_ID=

# -----------------------------------------
# EMAIL (Notificações)
# -----------------------------------------
# RESEND_API_KEY=

# -----------------------------------------
# IMPORTANTE
# -----------------------------------------
# 1. Nunca commite este arquivo com valores reais
# 2. Configure na sua plataforma via Dashboard
# 3. Após deploy, atualize NEXT_PUBLIC_APP_URL
# 4. Atualize URLs de callback no Meta Developer Console

# WhatsApp OpenClaw webhook
WHATSAPP_WEBHOOK_SECRET=change_me

CAMPAIGN_SQUAD_SERVICE_URL=http://localhost:4010

CAMPAIGN_SQUAD_INTERNAL_SECRET=

# Jira backlog integration (Campaign Squad)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-jira-email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=PROJ
JIRA_EPIC_ISSUE_TYPE=Epic
JIRA_STORY_ISSUE_TYPE=Story
# Optional custom field ids (company specific)
# JIRA_STORY_POINTS_FIELD_ID=customfield_10016
# JIRA_EPIC_NAME_FIELD_ID=customfield_10011
# JIRA_EPIC_LINK_FIELD_ID=customfield_10014
