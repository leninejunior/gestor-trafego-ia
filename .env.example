# ===========================================
# CONFIGURAÇÃO DE AMBIENTE - ADS MANAGER
# ===========================================

# -----------------------------------------
# SUPABASE (Obrigatório)
# -----------------------------------------
# URL do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Chave anônima (pública) do Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Chave de serviço (privada) - NUNCA exponha no frontend
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------
# API V1 (Fallback quando api_keys nao existir)
# -----------------------------------------
# Opcional: chave unica para autenticar /api/v1/*
API_V1_FALLBACK_KEY=sk_your_fallback_key
API_V1_FALLBACK_ORGANIZATION_ID=your_org_uuid
API_V1_FALLBACK_PERMISSIONS=balance:read,campaigns:read,campaigns:write

# Opcional: multiplas chaves em JSON
# API_V1_KEYS_JSON=[{"key":"sk_key_1","organizationId":"org_uuid_1","permissions":["*"]}]

# -----------------------------------------
# META ADS API (Obrigatório)
# -----------------------------------------
# ID do seu app no Meta Developer Console
META_APP_ID=your_meta_app_id

# Secret do seu app (privado)
META_APP_SECRET=your_meta_app_secret

# Token de acesso (opcional - pode ser configurado via UI)
META_ACCESS_TOKEN=your_meta_access_token

# -----------------------------------------
# APLICAÇÃO (Obrigatório)
# -----------------------------------------
# URL base da aplicação (importante para OAuth callbacks)
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to protect /api/cron/* endpoints
CRON_SECRET=your_secure_cron_secret

# -----------------------------------------
# GOOGLE ADS API (Para Integração Google Ads)
# -----------------------------------------
# OAuth 2.0 Client ID do Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id

# OAuth 2.0 Client Secret do Google Cloud Console
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Developer Token do Google Ads (obtenha em Google Ads API Center)
GOOGLE_DEVELOPER_TOKEN=your_google_developer_token

# Chave de criptografia para tokens do Google Ads (gere uma chave segura aleatória)
# Use: openssl rand -base64 32
GOOGLE_TOKEN_ENCRYPTION_KEY=your_secure_random_encryption_key

# -----------------------------------------
# STRIPE (Para Sistema de Assinaturas)
# -----------------------------------------
# Chave pública do Stripe (pode ser exposta no frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Chave secreta do Stripe (NUNCA exponha no frontend)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Secret do webhook do Stripe (para verificar eventos)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# -----------------------------------------
# IUGU (Gateway de Pagamento Brasileiro)
# -----------------------------------------
# Token de API do Iugu (privado)
IUGU_API_TOKEN=your_iugu_api_token_here

# ID da conta Iugu
IUGU_ACCOUNT_ID=your_iugu_account_id_here

# ID da conta Iugu (público - para frontend)
NEXT_PUBLIC_IUGU_ACCOUNT_ID=your_iugu_account_id_here

# -----------------------------------------
# EMAIL (Opcional - Resend)
# -----------------------------------------
RESEND_API_KEY=your_resend_api_key

# -----------------------------------------
# BANCO DE DADOS (Opcional)
# -----------------------------------------
# Se usar PostgreSQL externo ao Supabase
DATABASE_URL=postgresql://user:password@host:port/database

# -----------------------------------------
# AMBIENTE (Automático)
# -----------------------------------------
# NODE_ENV é definido automaticamente pela plataforma de deploy
# NODE_ENV=production

# WhatsApp OpenClaw webhook
WHATSAPP_WEBHOOK_SECRET=change_me

CAMPAIGN_SQUAD_SERVICE_URL=http://localhost:4010

CAMPAIGN_SQUAD_INTERNAL_SECRET=

# Jira backlog integration (Campaign Squad)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-jira-email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=PROJ
JIRA_EPIC_ISSUE_TYPE=Epic
JIRA_STORY_ISSUE_TYPE=Story
# Optional custom field ids (company specific)
# JIRA_STORY_POINTS_FIELD_ID=customfield_10016
# JIRA_EPIC_NAME_FIELD_ID=customfield_10011
# JIRA_EPIC_LINK_FIELD_ID=customfield_10014
