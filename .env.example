# ===========================================
# CONFIGURAÇÃO DE AMBIENTE - ADS MANAGER
# ===========================================

# -----------------------------------------
# SUPABASE (Obrigatório)
# -----------------------------------------
# URL do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Chave anônima (pública) do Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Chave de serviço (privada) - NUNCA exponha no frontend
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------
# META ADS API (Obrigatório)
# -----------------------------------------
# ID do seu app no Meta Developer Console
META_APP_ID=your_meta_app_id

# Secret do seu app (privado)
META_APP_SECRET=your_meta_app_secret

# Token de acesso (opcional - pode ser configurado via UI)
META_ACCESS_TOKEN=your_meta_access_token

# -----------------------------------------
# APLICAÇÃO (Obrigatório)
# -----------------------------------------
# URL base da aplicação (importante para OAuth callbacks)
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------
# GOOGLE ADS API (Opcional - Futuro)
# -----------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------------------
# STRIPE (Opcional - Para Pagamentos)
# -----------------------------------------
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# -----------------------------------------
# EMAIL (Opcional - Resend)
# -----------------------------------------
RESEND_API_KEY=your_resend_api_key

# -----------------------------------------
# BANCO DE DADOS (Opcional)
# -----------------------------------------
# Se usar PostgreSQL externo ao Supabase
DATABASE_URL=postgresql://user:password@host:port/database

# -----------------------------------------
# AMBIENTE (Automático)
# -----------------------------------------
# NODE_ENV é definido automaticamente pela Vercel
# NODE_ENV=production