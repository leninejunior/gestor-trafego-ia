# ===========================================
# Flying Fox V2 - Staging Environment Example
# GT-19: V2-11 Deploy V2 na VPS
# ===========================================

# Nunca commitar valores reais. Use apenas placeholders.

# App
NODE_ENV=production
STAGING_HTTP_PORT=8080
STAGING_PUBLIC_URL=https://staging.flyingfox.local

# Banco/Auth
DATABASE_URL=postgresql://user:password@db-host:5432/flying_fox_v2?schema=public
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Backup Postgres (GT-20)
# Se vazio, usa DATABASE_URL
BACKUP_DATABASE_URL=
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_SECONDS=86400

# Papi (GT-18)
PAPI_BASE_URL=https://papi.example.com
PAPI_API_KEY=your_papi_api_key
PAPI_GROUP_ID=grupo@chat
PAPI_SEND_PATH=/messages/group/send
PAPI_TIMEOUT_MS=10000

# Cutover gradual e rollback rapido (GT-22)
CUTOVER_DEFAULT_ROUTE=V2
CUTOVER_ROLLOUT_SALT=gt22-cutover
CUTOVER_ROLLBACK_USER_ID=00000000-0000-0000-0000-000000000000

# API IA - seguranca e governanca (GT-24)
AI_DEFAULT_RATE_LIMIT_PER_MINUTE=60
AI_SERVICE_TOKENS_JSON=[{"token":"staging_ai_token_change_me","keyId":"ai-staging","organizationId":"org-1","scopes":["ai:read_campaigns"],"rateLimitPerMinute":60}]
AI_CONTEXT_ANOMALY_THRESHOLD_PERCENT=30
