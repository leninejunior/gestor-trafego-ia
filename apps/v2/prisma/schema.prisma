generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Healthcheck {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  @@map("healthchecks")
}

model User {
  id          String    @id @db.Uuid
  email       String?
  fullName    String?   @map("full_name")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")
  memberships Membership[]

  @@index([email], map: "users_email_idx")
  @@map("users")
}

model Organization {
  id              String           @id @default(cuid())
  name            String
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  memberships     Membership[]
  clients         Client[]
  metaConnections MetaConnection[]
  campaigns       Campaign[]
  cutoverRules    CutoverRule[]
  aiApiAuditLogs  AiApiAuditLog[]

  @@map("organizations")
}

model Membership {
  id             String       @id @default(cuid())
  userId         String       @db.Uuid @map("user_id")
  organizationId String       @map("organization_id")
  role           UserRole     @default(REGULAR)
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId], map: "uq_membership_user_org")
  @@index([organizationId], map: "idx_membership_org")
  @@map("memberships")
}

model Client {
  id             String          @id @default(cuid())
  organizationId String          @map("organization_id")
  name           String
  externalId     String?         @map("external_id")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connections    MetaConnection[]
  campaigns      Campaign[]
  cutoverRules   CutoverRule[]

  @@index([organizationId], map: "idx_client_org")
  @@unique([organizationId, externalId], map: "uq_client_org_external")
  @@map("clients")
}

model MetaConnection {
  id            String       @id @default(cuid())
  organizationId String      @map("organization_id")
  clientId      String?      @map("client_id")
  provider      String       @default("meta")
  accountId     String       @map("account_id")
  accountName   String?      @map("account_name")
  accessToken   String?      @map("access_token")
  refreshToken  String?      @map("refresh_token")
  tokenExpiresAt DateTime?   @map("token_expires_at")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@unique([organizationId, provider, accountId], map: "uq_conn_org_provider_account")
  @@index([organizationId], map: "idx_conn_org")
  @@index([clientId], map: "idx_conn_client")
  @@map("meta_connections")
}

model Campaign {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  clientId       String?        @map("client_id")
  externalId     String         @map("external_id")
  name           String
  status         CampaignStatus @default(UNKNOWN)
  spend          Decimal?       @db.Decimal(14, 2)
  impressions    Int?
  clicks         Int?
  leads          Int?
  snapshotDate   DateTime       @map("snapshot_date")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([organizationId], map: "idx_campaign_org")
  @@index([clientId], map: "idx_campaign_client")
  @@unique([organizationId, externalId, snapshotDate], map: "uq_campaign_snapshot")
  @@map("campaigns")
}

model CutoverRule {
  id              String       @id @default(cuid())
  organizationId  String       @map("organization_id")
  clientId        String?      @map("client_id")
  groupId         String?      @map("group_id")
  route           CutoverRoute @default(V1)
  rolloutPercent  Int          @default(0) @map("rollout_percent")
  isActive        Boolean      @default(true) @map("is_active")
  reason          String?
  createdByUserId String       @db.Uuid @map("created_by_user_id")
  updatedByUserId String?      @db.Uuid @map("updated_by_user_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([organizationId, isActive], map: "idx_cutover_rule_org_active")
  @@index([organizationId, groupId, isActive], map: "idx_cutover_rule_org_group_active")
  @@index([organizationId, clientId, isActive], map: "idx_cutover_rule_org_client_active")
  @@map("cutover_rules")
}

model AiApiAuditLog {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  keyId          String       @map("key_id")
  endpoint       String
  method         String
  statusCode     Int          @map("status_code")
  scope          String
  filters        Json?
  rateLimited    Boolean      @default(false) @map("rate_limited")
  ipAddress      String?      @map("ip_address")
  userAgent      String?      @map("user_agent")
  requestId      String?      @map("request_id")
  errorMessage   String?      @map("error_message")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt], map: "idx_ai_api_audit_org_created")
  @@index([keyId, createdAt], map: "idx_ai_api_audit_key_created")
  @@map("ai_api_audit_logs")
}

enum UserRole {
  MASTER
  REGULAR
  CLIENT
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  ARCHIVED
  UNKNOWN
}

enum CutoverRoute {
  V1
  V2
}

enum AnamnesisSpecialty {
  ESTETICA
  PSICOLOGIA
  CLINICA_GERAL
}

model AnamnesisTemplate {
  id              String             @id @default(cuid())
  tenantId        String             @map("tenant_id")
  specialty       AnamnesisSpecialty
  name            String
  description     String?
  formSchema      Json               @map("form_schema")
  isActive        Boolean            @default(true) @map("is_active")
  createdByUserId String             @map("created_by_user_id")
  updatedByUserId String?            @map("updated_by_user_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([tenantId, specialty, isActive], map: "anamnesis_templates_tenant_specialty_active_idx")
  @@map("anamnesis_templates")
}
