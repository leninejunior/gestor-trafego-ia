# ===========================================
# Flying Fox V2 - Environment Example
# GT-10: V2-2 Configurar ambientes e secrets
# ===========================================

# Variaveis obrigatorias (usar placeholders, nunca commitar secrets reais):
# - DATABASE_URL
# - SUPABASE_URL
# - SUPABASE_ANON_KEY
# - SUPABASE_JWT_SECRET
# - SOURCE_DATABASE_URL (GT-15, opcional para ETL)
# - TARGET_DATABASE_URL (GT-15, opcional para sobrescrever DATABASE_URL no ETL)
# - DELTA_SINCE (GT-16, opcional para forcar cursor inicial do sync delta)
# - DELTA_RETRY_MAX_ATTEMPTS (GT-16, opcional; padrao: 3)
# - DELTA_RETRY_BASE_DELAY_MS (GT-16, opcional; padrao: 300)
# - PARITY_TOLERANCE_PERCENT (GT-21, opcional; padrao: 1)
# - BILLING_UPSTREAM_BASE_URL (opcional; ex.: https://app.flyingfox.com para proxy do checkout/upgrade)
# - PAPI_BASE_URL (GT-18)
# - PAPI_API_KEY (GT-18)
# - PAPI_GROUP_ID (GT-18)
# - PAPI_SEND_PATH (GT-18, opcional; padrao: /messages/group/send)
# - PAPI_TIMEOUT_MS (GT-18, opcional; padrao: 10000)
# - CUTOVER_DEFAULT_ROUTE (GT-22, opcional; V1 ou V2, padrao: V2)
# - CUTOVER_ROLLOUT_SALT (GT-22, opcional; sal para hash deterministico do rollout)
# - CUTOVER_ROLLBACK_USER_ID (GT-22, opcional; UUID usado no script de rollback)
# - AI_SERVICE_TOKENS_JSON (GT-24, obrigatorio para API IA; lista JSON de tokens + escopos)
# - AI_DEFAULT_RATE_LIMIT_PER_MINUTE (GT-24, opcional; padrao: 60)
# - AI_CONTEXT_ANOMALY_THRESHOLD_PERCENT (GT-25, opcional; padrao: 30)
# - Para deploy staging (GT-19), usar `.env.staging.example` como base de `.env.staging`
# - Para deploy producao VPS (GT-19.1), usar `.env.production.example` como base de `.env.production`
# - SSL_DOMAIN / SSL_EMAIL / PROD_HTTPS_PORT (GT-19.1 SSL)
# - BACKUP_DATABASE_URL / BACKUP_RETENTION_DAYS / BACKUP_INTERVAL_SECONDS (GT-20, em `.env.staging` ou `.env.production`)

# ---------------------------
# Dev (.env)
# ---------------------------
DATABASE_URL="postgresql://v2:v2@localhost:5434/flying_fox_v2?schema=public"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_JWT_SECRET="your_supabase_jwt_secret"
# SOURCE_DATABASE_URL="postgresql://user:pass@legacy-host:5432/legacy_db?schema=public"
# TARGET_DATABASE_URL="postgresql://v2:v2@localhost:5434/flying_fox_v2?schema=public"
# DELTA_SINCE="2026-01-01T00:00:00.000Z"
# DELTA_RETRY_MAX_ATTEMPTS="3"
# DELTA_RETRY_BASE_DELAY_MS="300"
# PARITY_TOLERANCE_PERCENT="1"
# BILLING_UPSTREAM_BASE_URL="https://app.flyingfox.com"
# PAPI_BASE_URL="https://papi.example.com"
# PAPI_API_KEY="your_papi_api_key"
# PAPI_GROUP_ID="grupo@chat"
# PAPI_SEND_PATH="/messages/group/send"
# PAPI_TIMEOUT_MS="10000"
# CUTOVER_DEFAULT_ROUTE="V2"
# CUTOVER_ROLLOUT_SALT="gt22-cutover"
# CUTOVER_ROLLBACK_USER_ID="00000000-0000-0000-0000-000000000000"
# AI_DEFAULT_RATE_LIMIT_PER_MINUTE="60"
# AI_SERVICE_TOKENS_JSON='[{"token":"dev_ai_token_change_me","keyId":"ai-dev","organizationId":"org-1","scopes":["ai:read_campaigns"],"rateLimitPerMinute":60}]'
# AI_CONTEXT_ANOMALY_THRESHOLD_PERCENT="30"

# ---------------------------
# Staging (.env.staging) - exemplo
# ---------------------------
# DATABASE_URL="postgresql://user:pass@staging-host:5432/flying_fox_v2?schema=public"
# SUPABASE_URL="https://staging-project.supabase.co"
# SUPABASE_ANON_KEY="staging_supabase_anon_key"
# SUPABASE_JWT_SECRET="staging_supabase_jwt_secret"

# ---------------------------
# Producao (.env.production) - exemplo
# ---------------------------
# DATABASE_URL="postgresql://user:pass@prod-host:5432/flying_fox_v2?schema=public"
# SUPABASE_URL="https://prod-project.supabase.co"
# SUPABASE_ANON_KEY="prod_supabase_anon_key"
# SUPABASE_JWT_SECRET="prod_supabase_jwt_secret"
