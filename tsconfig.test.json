{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["jest", "@testing-library/jest-dom", "@types/node"],
    "isolatedModules": false,
    "noEmit": true
  },
  "include": [
    "**/__tests__/**/*.{js,jsx,ts,tsx}",
    "**/*.test.{js,jsx,ts,tsx}",
    "**/*.spec.{js,jsx,ts,tsx}"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build"
  ]
}